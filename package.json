{
  "name": "idol-diary",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -r ./scripts/exfat-readlink-shim.cjs ./node_modules/next/dist/bin/next dev",
    "dev:mobile": "node -r ./scripts/exfat-readlink-shim.cjs ./node_modules/next/dist/bin/next dev -H 0.0.0.0",
    "build": "node -r ./scripts/exfat-readlink-shim.cjs ./node_modules/next/dist/bin/next build",
    "mobile:dev": "powershell -ExecutionPolicy Bypass -File scripts/mobile-dev.ps1",
    "mobile:sync": "cap sync",
    "mobile:android": "cap open android",
    "mobile:ios": "cap open ios",
    "postinstall": "prisma generate",
    "start": "node -r ./scripts/exfat-readlink-shim.cjs ./node_modules/next/dist/bin/next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:init": "prisma db push && prisma db seed",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@vercel/blob": "^2.3.3",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "prisma": "^6.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "typescript": "^5.7.2"
  }
}
